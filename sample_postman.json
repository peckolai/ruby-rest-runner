          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"title\":\"Updated Title\",\"body\":\"Updated content\",\"userId\":1,\"id\":1}"
        }
      }
    },
    {
      "name": "Delete Post",
